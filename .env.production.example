# ===========================================
# PRODUCTION ENVIRONMENT
# ===========================================
NODE_ENV=production

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# URLs
BASE_URL=https://speech-to-text.me
CORS_ORIGIN=https://speech-to-text.me
REACT_APP_API_URL=

# Frontend (production build with nginx)
FRONTEND_DOCKERFILE=Dockerfile
FRONTEND_INTERNAL_PORT=80

# Traefik
TRAEFIK_ENABLE=true

# AdSense
REACT_APP_ADSENSE_ENABLED=true
REACT_APP_ADSENSE_CLIENT=ca-pub-5495300381182843

# Database (use strong passwords in production!)
POSTGRES_USER=speechtotext
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=speechtotext
