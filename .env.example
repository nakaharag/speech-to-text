# ===========================================
# Environment Configuration
# ===========================================
# Set to "development" for local dev or "production" for deployment
NODE_ENV=development

# ===========================================
# API Keys
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# URLs (adjust based on environment)
# ===========================================
# Development defaults:
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
# Legacy React frontend only:
REACT_APP_API_URL=http://localhost:3000

# Production values (uncomment for production):
# BASE_URL=https://speech-to-text.me
# CORS_ORIGIN=https://speech-to-text.me
# REACT_APP_API_URL=

# ===========================================
# Ports (for development)
# ===========================================
FRONTEND_PORT=3001
BACKEND_PORT=3000
POSTGRES_PORT=5432

# ===========================================
# Frontend Dockerfile
# ===========================================
# Use Dockerfile.dev for development (hot reload)
# Use Dockerfile for production (nginx)
FRONTEND_DOCKERFILE=Dockerfile.dev
FRONTEND_INTERNAL_PORT=3000

# Production values:
# FRONTEND_DOCKERFILE=Dockerfile
# FRONTEND_INTERNAL_PORT=80

# ===========================================
# Traefik (production only)
# ===========================================
TRAEFIK_ENABLE=false

# ===========================================
# Google AdSense (legacy frontend only)
# ===========================================
REACT_APP_ADSENSE_ENABLED=false
REACT_APP_ADSENSE_CLIENT=ca-pub-5495300381182843

# ===========================================
# Database
# ===========================================
POSTGRES_USER=speechtotext
POSTGRES_PASSWORD=speechtotext123
POSTGRES_DB=speechtotext
# DATABASE_URL is constructed automatically by docker-compose from the above

# ===========================================
# Next.js Frontend (frontend-next)
# ===========================================
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-secret-change-in-production-minimum-32-chars
BACKEND_URL=http://localhost:3000

# ===========================================
# OAuth Providers (optional)
# ===========================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# ===========================================
# Email Configuration (Resend)
# ===========================================
# Using Resend for transactional emails
# RESEND_API_KEY=re_your-resend-api-key
# EMAIL_FROM=noreply@speech-to-text.me

# ===========================================
# Stripe Payments (optional)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs for subscription plans
# NOTE: Variable names use STRIPE_PRICE_* format (matches code)
# STRIPE_PRICE_BASIC_MONTHLY=price_xxx
# STRIPE_PRICE_BASIC_YEARLY=price_xxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_YEARLY=price_xxx

# ===========================================
# Cloudflare R2 Storage (optional)
# ===========================================
# R2 storage for audio files. If not configured,
# audio will be stored as base64 in the database.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=speech-to-text-storage
# R2_PUBLIC_URL=  # Optional: public bucket URL for direct access
