# Development Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Database
# ===================
POSTGRES_USER=speechtotext
POSTGRES_PASSWORD=speechtotext123
POSTGRES_DB=speechtotext
# DATABASE_URL is constructed automatically by docker-compose from the above

# ===================
# Backend (NestJS)
# ===================
NODE_ENV=development
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CORS_ORIGIN=http://localhost:3001
BASE_URL=http://localhost:3000

# ===================
# Frontend (Next.js)
# ===================
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-secret-change-in-production-minimum-32-chars
BACKEND_URL=http://localhost:3000

# OAuth Providers (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email - Resend (optional for local dev)
# The code uses Resend API, not SMTP
RESEND_API_KEY=
EMAIL_FROM=noreply@speech-to-text.me

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs - NOTE: Use STRIPE_PRICE_* format (matches code)
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
