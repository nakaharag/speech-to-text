# ===========================================
# Next.js Frontend Environment Configuration
# ===========================================
# Copy this file to .env.local for development
# or set these as environment variables in production

# ===========================================
# NextAuth.js Configuration (Required)
# ===========================================
# The URL where your app is hosted
NEXTAUTH_URL=http://localhost:3001

# A random string for signing tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===========================================
# Database (Required)
# ===========================================
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/speechtotext

# ===========================================
# Backend API (Required)
# ===========================================
# URL to the Node.js backend service
BACKEND_URL=http://localhost:3000

# ===========================================
# OAuth Providers (Optional)
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (Sign in with Apple)
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ===========================================
# Email Configuration (Optional)
# ===========================================
# SMTP settings for sending emails (password reset, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@speech-to-text.me

# ===========================================
# Stripe Payments (Optional)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for subscription plans
# Create products/prices in Stripe Dashboard
STRIPE_BASIC_MONTHLY_PRICE_ID=
STRIPE_BASIC_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# ===========================================
# Public Environment Variables
# ===========================================
# These are exposed to the browser (prefix with NEXT_PUBLIC_)
# Add any client-side environment variables here
# NEXT_PUBLIC_EXAMPLE=value
