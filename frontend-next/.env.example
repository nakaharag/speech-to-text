# ===========================================
# Next.js Frontend Environment Configuration
# ===========================================
# Copy this file to .env.local for development
# or set these as environment variables in production

# ===========================================
# NextAuth.js Configuration (Required)
# ===========================================
# The URL where your app is hosted
NEXTAUTH_URL=http://localhost:3001

# A random string for signing tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===========================================
# Database (Required)
# ===========================================
# PostgreSQL connection string
# In docker-compose, this is constructed from POSTGRES_USER/PASSWORD/DB
DATABASE_URL=postgresql://speechtotext:speechtotext123@localhost:5432/speechtotext

# ===========================================
# Backend API (Required)
# ===========================================
# URL to the Node.js backend service
# In docker-compose, this is set to http://backend:3000
BACKEND_URL=http://localhost:3000

# ===========================================
# OAuth Providers (Optional)
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (Sign in with Apple)
APPLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ===========================================
# Email Configuration - Resend (Optional)
# ===========================================
# The code uses Resend API for transactional emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply@speech-to-text.me

# ===========================================
# Stripe Payments (Optional)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for subscription plans
# NOTE: Use STRIPE_PRICE_* format (not STRIPE_*_PRICE_ID)
# Create products/prices in Stripe Dashboard
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ===========================================
# Public Environment Variables
# ===========================================
# These are exposed to the browser (prefix with NEXT_PUBLIC_)
# Add any client-side environment variables here
# NEXT_PUBLIC_EXAMPLE=value
